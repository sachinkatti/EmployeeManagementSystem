@model X.PagedList.IPagedList<EmployeeManagementSystem.Models.Employee>

@using X.PagedList.Mvc.Core
@using X.PagedList
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Employees";
    var role = Context.Session.GetString("Role");
}

<div class="container mt-4">

    <!-- Heading -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary fw-bold">Employee List</h2>

        @if (role == "Admin" || role == "HR")
        {
            <a asp-action="Create" class="btn btn-success">
                + Add Employee
            </a>
        }
    </div>

    <!-- Search -->
    <form asp-action="Index" method="get" class="mb-3">

        <div class="row g-2">

            <div class="col-md-5">

                <input type="text"
                       name="searchString"
                       value="@ViewData["CurrentFilter"]"
                       class="form-control"
                       placeholder="Search by Name, Email or Department" />

            </div>

            <div class="col-auto">

                <input type="submit"
                       value="Search"
                       class="btn btn-primary" />

            </div>

            <div class="col-auto">

                <a asp-action="Index"
                       class="btn btn-secondary">
                    Reset
                </a>

            </div>

        </div>

    </form>

    <!-- Total Employees -->
    <div class="mb-3 text-muted">
        Total Employees :
        <strong>@Model.TotalItemCount</strong>
    </div>

    <!-- Employee Table -->
    <table class="table table-bordered table-hover table-striped shadow">

        <thead class="table-dark">

            <tr>

                <th>
                    <a asp-action="Index"
                           asp-route-sortOrder="@ViewData["NameSort"]"
                           asp-route-searchString="@ViewData["CurrentFilter"]"
                           class="text-white text-decoration-none">
                        Name
                    </a>
                </th>

                <th>Email</th>

                <th>Department</th>

                <th>
                    <a asp-action="Index"
                           asp-route-sortOrder="@ViewData["SalarySort"]"
                           asp-route-searchString="@ViewData["CurrentFilter"]"
                           class="text-white text-decoration-none">
                        Salary
                    </a>
                </th>

                <th>Joining Date</th>

                <th width="210">Actions</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Name</td>

                    <td>@item.Email</td>

                    <td>@item.Department</td>

                    <td>
                        @item.Salary.ToString("C2", new System.Globalization.CultureInfo("en-IN"))
                    </td>

                    <td>
                        @item.JoiningDate.ToString("dd-MMM-yyyy")
                    </td>

                    <td>

                        @if (role == "Admin" || role == "HR")
                        {
                            <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm me-1">
                                Edit
                            </a>
                        }

                        <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm text-white me-1">
                            Details
                        </a>

                        @if (role == "Admin")
                        {
                            <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">
                                Delete
                            </a>
                        }

                    </td>

                </tr>
            }

        </tbody>

    </table>

    <!-- Pagination -->
    @if (Model.PageCount > 1)
    {
        <div class="text-center mt-4">

            <nav aria-label="Employee Pagination">

                <ul class="pagination pagination-sm justify-content-center">

                    <!-- First -->
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="1"
                               asp-route-searchString="@ViewData["CurrentFilter"]"
                               asp-route-sortOrder="@ViewData["CurrentSort"]">
                            &laquo;
                        </a>
                    </li>

                    <!-- Previous -->
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.PageNumber - 1)"
                               asp-route-searchString="@ViewData["CurrentFilter"]"
                               asp-route-sortOrder="@ViewData["CurrentSort"]">
                            &lsaquo;
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.PageCount; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-searchString="@ViewData["CurrentFilter"]"
                                   asp-route-sortOrder="@ViewData["CurrentSort"]">
                                @i
                            </a>
                        </li>
                    }

                    <!-- Next -->
                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.PageNumber + 1)"
                               asp-route-searchString="@ViewData["CurrentFilter"]"
                               asp-route-sortOrder="@ViewData["CurrentSort"]">
                            &rsaquo;
                        </a>
                    </li>

                    <!-- Last -->
                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@Model.PageCount"
                               asp-route-searchString="@ViewData["CurrentFilter"]"
                               asp-route-sortOrder="@ViewData["CurrentSort"]">
                            &raquo;
                        </a>
                    </li>

                </ul>

            </nav>

            <div class="text-muted small mt-2">
                Page <strong>@Model.PageNumber</strong> of
                <strong>@Model.PageCount</strong>
            </div>

        </div>
    }

</div>